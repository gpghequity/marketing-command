<%- include('partials/header', { pageTitle: 'Dashboard', bodyClass: 'page-admin' }) %>

<section class="admin-shell">
  <div class="admin-inner">

    <div class="admin-main">
      <div class="admin-header">
        <h1>Dashboard</h1>
        <p>Incoming leads and pipeline health for Marketing Command.</p>
      </div>

      <div class="stats-row">
        <div class="stat-card">
          <div class="stat-label">Total Intakes</div>
          <div class="stat-value"><%= stats.total %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">This Week</div>
          <div class="stat-value"><%= stats.thisWeek %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Conversion Rate</div>
          <div class="stat-value"><%= stats.conversionRate %>%</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Est. MRR Pipeline</div>
          <div class="stat-value">$<%= stats.estimatedMRR.toLocaleString() %><span style="font-size: 15px; color: var(--gray-500); font-family: var(--sans);">/mo</span></div>
        </div>
      </div>

      <div class="intakes-card" id="intakes">
        <h2>Intakes</h2>
        <table class="intakes-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Business</th>
              <th>Package</th>
              <th>Interest</th>
              <th>Submitted</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% intakes.forEach(function(i) { %>
              <tr class="intake-row" data-intake='<%- JSON.stringify(i).replace(/'/g, "&#39;") %>'>
                <td class="name-cell"><%= i.firstName %> <%= i.lastName %></td>
                <td><%= i.businessName || '—' %></td>
                <td><%= i.package %></td>
                <td><%= i.timing || '—' %></td>
                <td><%= i.submittedAt %></td>
                <td><span class="status-pill status-<%= i.status %>"><%= i.status %></span></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>

    <aside class="sidebar-card">
      <h2>Pipeline Health</h2>
      <div class="sidebar-stat"><span class="label">Avg response time</span><span class="value">4.2 hours</span></div>
      <div class="sidebar-stat"><span class="label">Avg time to close</span><span class="value">8.5 days</span></div>
      <div class="sidebar-stat"><span class="label">Top source</span><span class="value">Referral (67%)</span></div>
      <div class="sidebar-stat"><span class="label">Top package</span><span class="value">Growth (44%)</span></div>
    </aside>
  </div>
</section>

<div class="modal-overlay" id="intake-modal">
  <div class="modal">
    <div class="modal-head">
      <div>
        <h2 id="m-name"></h2>
        <p id="m-contact"></p>
      </div>
      <button class="modal-close" id="m-close" type="button">&times;</button>
    </div>
    <div class="modal-body" id="m-body"></div>
    <div class="modal-actions">
      <form method="POST" id="status-form" style="display: contents;">
        <button type="submit" name="status" value="CONTACTED">Mark Contacted</button>
        <button type="submit" name="status" value="QUOTED">Mark Quoted</button>
        <button type="submit" name="status" value="CONVERTED">Convert to Customer</button>
        <button type="submit" name="status" value="DECLINED" class="danger">Decline</button>
      </form>
    </div>
  </div>
</div>

<%- include('partials/cross-sell') %>

<script>
  var modal = document.getElementById('intake-modal');
  var mName = document.getElementById('m-name');
  var mContact = document.getElementById('m-contact');
  var mBody = document.getElementById('m-body');
  var statusForm = document.getElementById('status-form');

  function renderDetail(label, value) {
    if (!value || (Array.isArray(value) && !value.length)) value = '—';
    if (Array.isArray(value)) value = value.join(', ');
    return '<div class="detail-group"><div class="detail-label">' + label + '</div><div class="detail-value">' + escapeHtml(String(value)) + '</div></div>';
  }

  function escapeHtml(s) {
    return s.replace(/[&<>"']/g, function(c) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
    });
  }

  document.querySelectorAll('.intake-row').forEach(function(row) {
    row.addEventListener('click', function() {
      var data = JSON.parse(row.getAttribute('data-intake'));
      mName.textContent = data.firstName + ' ' + data.lastName;
      mContact.textContent = data.email + '  ·  ' + data.phone;
      mBody.innerHTML =
        renderDetail('Business', (data.businessName || '—') + ' (' + (data.businessType || '—') + ')') +
        renderDetail('Markets', data.markets) +
        renderDetail('Years in business', data.years) +
        renderDetail('Current tools', data.currentTools) +
        renderDetail('Pain point', data.painPoint) +
        renderDetail('Current monthly spend', data.currentSpend) +
        renderDetail('Goals', data.goals) +
        (data.otherGoal ? renderDetail('Other goal', data.otherGoal) : '') +
        renderDetail('Package interest', data.package) +
        renderDetail('Timing', data.timing) +
        renderDetail('Budget', data.budget) +
        renderDetail('Notes', data.notes) +
        renderDetail('Source', data.source) +
        renderDetail('Submitted', data.submittedAt) +
        renderDetail('Status', data.status);
      statusForm.action = '/admin/intake/' + data.id + '/status';
      modal.classList.add('open');
    });
  });

  document.getElementById('m-close').addEventListener('click', function() { modal.classList.remove('open'); });
  modal.addEventListener('click', function(e) { if (e.target === modal) modal.classList.remove('open'); });
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') modal.classList.remove('open'); });
</script>

<%- include('partials/footer') %>

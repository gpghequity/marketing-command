<section class="cross-sell">
  <div class="cross-sell-inner">
    <h2>Part of the Projects with a Purpose Platform</h2>
    <p class="cross-sell-sub">Seven products. One operating system for serious real estate operators.</p>
    <div class="cross-sell-grid">
      <% const pwpProducts = [
        { code: 'RH', name: 'REI Homepage', desc: 'Deal analysis and submission tool', url: 'https://rei-homepage-deal-analysis-production.up.railway.app' },
        { code: 'TC', name: 'Transaction Command', desc: 'Transaction compliance and document review', url: 'http://localhost:3003' },
        { code: 'AC', name: 'Agent Command', desc: 'Agent onboarding, training, brokerage ops', url: 'http://localhost:3004' },
        { code: 'LC', name: 'Lender Command', desc: 'Private lending intake and AI underwriting', url: 'http://localhost:3005' },
        { code: 'DC', name: 'Data Command', desc: 'Real estate data platform — skip trace, lists, comps', url: 'http://localhost:3006' },
        { code: 'BC', name: 'Broker Command', desc: 'Brokerage executive operating system', url: 'http://localhost:3007' }
      ]; %>
      <% pwpProducts.forEach(function(p) { %>
        <a href="<%= p.url %>" target="_blank" rel="noopener" class="cross-sell-card">
          <span class="badge"><%= p.code %></span>
          <h3><%= p.name %></h3>
          <p><%= p.desc %></p>
          <span class="cross-sell-open">Open <span aria-hidden="true">↗</span></span>
        </a>
      <% }); %>
    </div>
  </div>
</section>

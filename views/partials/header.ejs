<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' — ' : '' %>Marketing Command</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : '' %>">
  <header class="site-nav">
    <div class="nav-inner">
      <a href="/" class="nav-brand">
        <span class="badge">MC</span>
        <span class="brand-text">Marketing Command</span>
      </a>
      <nav class="nav-links">
        <% if (isLoggedIn) { %>
          <a href="/admin-dashboard">Dashboard</a>
          <a href="/admin-dashboard#intakes">Intakes</a>
          <a href="/tools">Tools</a>
          <a href="/about">About</a>
          <a href="/logout" class="nav-btn-ghost">Logout</a>
        <% } else { %>
          <a href="/tools">Tools</a>
          <a href="/packages">Packages</a>
          <a href="/get-started" class="nav-btn-gold">Get Started</a>
          <a href="/login" class="nav-link-muted">Login</a>
        <% } %>
      </nav>
    </div>
  </header>
